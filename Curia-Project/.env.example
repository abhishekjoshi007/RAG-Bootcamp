# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit actual keys.

# ── Required for LLM generation (omit only if you run --local everywhere) ────
OPENAI_API_KEY=sk-...

# ── Optional: multi-LLM benchmarking providers ───────────────────────────────
# Used by eval/run_multi_llm_eval.py to compare faithfulness/latency/cost
# across frontier LLMs. Any subset works — missing keys cause the corresponding
# models to be skipped with reason "missing_key".
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=
XAI_API_KEY=xai-...
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=sk-or-v1-...

# Optional OpenAI-compatible endpoint overrides.
# OPENAI_BASE_URL=
# GOOGLE_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# XAI_BASE_URL=https://api.x.ai/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OLLAMA_BASE_URL=http://localhost:11434

# Optional fallback token prices (USD per 1M tokens) used by the benchmark
# budget preflight when a registry entry has no pinned pricing.
CURIA_UNKNOWN_INPUT_COST_PER_MTOK=5
CURIA_UNKNOWN_OUTPUT_COST_PER_MTOK=15

# ── Optional: USAJOBS federal job postings ───────────────────────────────────
# Register free at https://developer.usajobs.gov/
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=your-email@example.com

# ── Optional: GitHub higher rate limit (60 → 5,000 req/hr) ──────────────────
GITHUB_TOKEN=ghp_...

# ── Optional: BigQuery / external corpora ────────────────────────────────────
# Set GCP_PROJECT_ID + GOOGLE_APPLICATION_CREDENTIALS to enable GitHub Archive
# ingestion via BigQuery. The credentials file MUST be outside the repo or
# matched by .gitignore (curia-rag-research-*.json / gcp-*.json patterns).
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Optional local data paths
STACKOVERFLOW_DUMP_PATH=
BLS_EXPORT_PATH=
ESCO_CROSSWALK_PATH=
